mat_df <- mat_df %>% mutate(Row = row_number())
# Use pivot_longer() to convert from wide to long format
mat_long <- mat_df %>%
pivot_longer(cols = !Row,
names_to = "Column",
values_to = "Value") %>%
mutate(Column = as.numeric(gsub("node:", "", Column))) %>%
rename(X = Row, Y = Column)
return(mat_long)
}
