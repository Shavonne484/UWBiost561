#' matrix containing only 0s and 1s, with 1s on the diagonal and no row or column names.
#' @export
#'
#' @examples
#' output <- generate_partial_clique(
#'   n = 10,
#'   clique_fraction = 0.4,
#'   clique_edge_density = 0.8
#' )
#'
generate_partial_clique <- function(n = 50,
clique_fraction = 0.2,
clique_edge_density = 1,
density_low = 0.1) {
stopifnot(n %% 1 == 0, n > 0,
clique_fraction >= 0, clique_fraction <= 1,
clique_edge_density >= 0, clique_edge_density <=1,
density_low >= 0, density_low <=1)
adj_mat <- matrix(sample(x = c(0, 1),
size = n^2,
prob = c(1 - density_low, density_low),
replace = TRUE),
nrow = n, ncol = n)
adj_mat <- adj_mat + t(adj_mat)
adj_mat[adj_mat > 0] <- 1
diag(adj_mat) <- 1
clique_size <- round(n * clique_fraction)
if (clique_size >= 2){
possible_edge <- t(combn(1:clique_size, 2))
max_edge <- clique_size * (clique_size - 1) / 2
act_edge <- round(clique_edge_density*clique_size*(clique_size-1)/2)
adj_mat[1:clique_size, 1:clique_size] <- 0
diag(adj_mat)[1:clique_size] <- 1
if (act_edge > 0) {
selected_edge <- possible_edge[
sample(1:max_edge, size = act_edge, replace = FALSE),
,
drop = FALSE
]
for (i in 1:nrow(selected_edge)) {
node1 <- selected_edge[i, 1]
node2 <- selected_edge[i, 2]
adj_mat[node1, node2] <- 1
adj_mat[node2, node1] <- 1
}
}
}
rownames(adj_mat) <- NULL
colnames(adj_mat) <- NULL
return(list(adj_mat = adj_mat))
}
