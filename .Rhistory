library(bookdown)
library(tidyverse)
library(ggplot2)
country_population <- readr::read_csv("https://raw.githubusercontent.com/linnykos/561_s2026_public/main/HW2_files/country_population.csv")
country_population
country_birth <- readr::read_csv("https://raw.githubusercontent.com/linnykos/561_s2026_public/main/HW2_files/country_birth.csv")
country_birth
country_population %>%
filter(between(year,1990,2010)) %>%
group_by(iso3c,country) %>%
summarize(mean_popoulation = mean(population))
knitr::include_graphics("https://raw.githubusercontent.com/linnykos/561_s2026_public/main/HW2_files/population.png")
country_birth %>%
filter(between(year,1990,2010)) %>%
filter(!is.na(iso3c)) %>%
filter(!is.na(year)) %>%
filter(!is.na(life_expect)) %>%
group_by(iso3c) %>%
summarise(min_life_expect = min(life_expect),
max_life_expect = max(life_expect)) %>%
mutate(range_life_expect = max_life_expect - min_life_expect)
knitr::include_graphics("https://raw.githubusercontent.com/linnykos/561_s2026_public/main/HW2_files/birth.png")
country_both <- inner_join(country_population,country_birth,by = "iso3c")
print(head(country_both,10))
dim(country_both)
penguins <- readr::read_csv("https://raw.githubusercontent.com/linnykos/561_s2026_public/main/HW2_files/palmerpenguins.csv")
penguins
penguins %>%
ggplot(aes(x = bill_depth_mm, y = bill_length_mm)) +
geom_point()
knitr::include_graphics("https://raw.githubusercontent.com/linnykos/561_s2026_public/main/HW2_files/scatterplot-colored.png")
scatter_plot <- ggplot(
data = penguins,
aes(x = bill_depth_mm, y = bill_length_mm, color = species)
) +
geom_point() +
scale_color_manual(
values = c(
"Adelie" = "cornflowerblue",
"Chinstrap" = "coral2",
"Gentoo" = "goldenrod3"
)
) +
labs(
x = "Bill Depth (mm)",
y = "Bill length (mm)",
title = paste("Relation among", nrow(penguins), "penguins")
)
scatter_plot
knitr::include_graphics("https://raw.githubusercontent.com/linnykos/561_s2026_public/main/HW2_files/facet.png")
facet_plot <- ggplot(
data = penguins,
aes(x = bill_depth_mm, y = bill_length_mm, color = species)
) +
geom_point(aes(alpha = "0.5")) +
geom_smooth(method = "lm", se = FALSE) +
facet_wrap(~ species) +
scale_color_manual(
values = c(
"Adelie" = "cornflowerblue",
"Chinstrap" = "coral2",
"Gentoo" = "goldenrod3"
)
) +
scale_alpha_manual(
values = c("0.5" = 0.5),
name = "alpha"
) +
labs(
x = "Bill Depth (mm)",
y = "Bill length (mm)",
title = paste("Relation among", nrow(penguins), "penguins")
) +
theme_bw()
